      "source": [
        "## Specify Dynamical System {auto-animate=true}\n",
        "\n",
        ":::: {.columns}\n",
        "\n",
        "::: {.column width=\"50%\"}\n",
        "\n",
        "::: {.fragment fragment-index=1}\n",
        "\n",
        "```yaml\n",
        "name: PendulumSystem\n",
        "parameters:\n",
        "    c:\n",
        "        value: 0.001\n",
        "        unit: 1/ms\n",
        "        description: damping coefficient\n",
        "    omega0:\n",
        "        value: 0.01\n",
        "        unit: rad/ms\n",
        "        description: natural frequency\n",
        "    L:\n",
        "        value: 1.0\n",
        "        unit: m\n",
        "        description: rod length\n",
        "\n",
        "state_variables:\n",
        "    theta:\n",
        "        unit: rad\n",
        "        initial_value: 1.0\n",
        "        equation: {rhs: omega}\n",
        "    omega:\n",
        "        unit: rad/ms\n",
        "        initial_value: 0.0\n",
        "        equation: {rhs: -c*omega - omega0**2 * sin(theta)}\n",
        "```\n",
        ":::\n",
        ":::\n",
        "::: {.column width=\"50%\"}\n",
        "\n",
        "::: {.fragment fragment-index=2}\n",
        "```python\n",
        "from tvbo import Dynamics\n",
        "pendulum = Dynamics.from_string(dynamics_yaml)\n",
        "pendulum.render('report')\n",
        "```\n",
        ":::\n",
        "\n",
        "\n",
        "::: {.fragment fragment-index=3 style=\"font-size: 0.7em;\"}\n",
        "\n",
        "#### PendulumSystem\n",
        "\n",
        "\n",
        "##### State Equations\n",
        "$$\n",
        "\\dot{\\theta} = \\omega\n",
        "$$\n",
        "$$\n",
        "\\dot{\\omega} = - c*\\omega - \\omega_{0}^{2}*\\sin{\\left(\\theta \\right)}\n",
        "$$\n",
        "\n",
        "##### Parameters\n",
        "\n",
        "| **Parameter** | **Value** | **Unit** | **Description** |\n",
        "|---------------|-----------|----------|-----------------|\n",
        "| $c$ | 0.001 | $\\mathrm{ms}^{-1}$ | damping coefficient |\n",
        "| $\\omega_{0}$ | 0.01 | $\\frac{\\mathrm{rad}}{\\mathrm{ms}}$ | natural frequency |\n",
        "| $L$ | 1.0 | $\\mathrm{m}$ | rod length |\n",
        ":::\n",
        "\n",
        ":::\n",
        "\n",
        "::::\n",
        "\n",
        "## Specify Dynamical System\n",
        "\n",
        ":::: {.columns}\n",
        "\n",
        "::: {.column width=\"50%\"}\n",
        "\n",
        "```python\n",
        "from tvbo import Dynamics\n",
        "pendulum = Dynamics.from_string(dynamics_yaml)\n",
        "pendulum.render('tvboptim')\n",
        "```\n",
        "\n",
        "::: {.fragment fragment-index=2}\n",
        "```\n",
        "import jax.numpy as jnp\n",
        "import jax.scipy as jsp\n",
        "\n",
        "\n",
        "def dfun(current_state, t, cX, _p):\n",
        "    # Parameters\n",
        "    c = _p.c\n",
        "    omega0 = _p.omega0\n",
        "    L = _p.L\n",
        "\n",
        "    # State variables\n",
        "    theta = current_state[0]\n",
        "    omega = current_state[1]\n",
        "\n",
        "    # Derivatives\n",
        "    dtheta_dt = omega\n",
        "    domega_dt = -c * omega - omega0**2 * jnp.sin(theta)\n",
        "\n",
        "    derivatives = jnp.array([dtheta_dt, domega_dt])\n",
        "\n",
        "    return derivatives\n",
        "```\n",
        ":::\n",
        "\n",
        ":::\n",
        "\n",
        "\n",
        "::: {.column}\n",
        "\n",
        "::: {.fragment fragment-index=3}\n",
        "```python\n",
        "SimulationExperiment(\n",
        "  dynamics=pendulum,\n",
        "  ).run()\n",
        "```\n",
        ":::\n",
        "\n",
        "::: {.fragment fragment-index=4}\n",
        "![](figures/pendulum.gif){height=550px}\n",
        ":::\n",
        "\n",
        ":::\n",
        "::::\n",
        "\n",
        "\n",
        "## Specify Network"
      ],
      "id": "15ba8e81"
    },
    {
      "cell_type": "code",
      "metadata": {
        "output-location": "column"
      },
      "source": [
        "#| code-line-numbers: 1-4|6-9|11-13|14-16|17-19|\n",
        "#| echo: true\n",
        "\n",
        "from tvbo import Network\n",
        "\n",
        "net = Network.from_string(\"\"\"\n",
        "label: Visual Pathway\n",
        "\n",
        "nodes:\n",
        "  - {id: 0, label: V1}\n",
        "  - {id: 1, label: V2}\n",
        "  - {id: 2, label: MT}\n",
        "\n",
        "edges:\n",
        "  - source: 0\n",
        "    target: 1\n",
        "    parameters:\n",
        "      weight:\n",
        "        value: 0.7\n",
        "      distance:\n",
        "        value: 25\n",
        "        unit: mm\n",
        "  - source: 1\n",
        "    target: 2\n",
        "    parameters:\n",
        "      weight:\n",
        "        value: 0.4\n",
        "      distance:\n",
        "        value: 40\n",
        "        unit: mm\n",
        "  - source: 0\n",
        "    target: 2\n",
        "    parameters:\n",
        "      weight:\n",
        "        value: 0.2\n",
        "      distance:\n",
        "        value: 60\n",
        "        unit: mm\n",
        "\"\"\")\n",
        "\n",
        "net.plot_graph()"
      ],
