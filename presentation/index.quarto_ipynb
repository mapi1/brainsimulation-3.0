        "  font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;\n",
        "  background: linear-gradient(145deg, #f4f8f8, #e4edef);\n",
        "  border: 2px solid #9ab5b8; border-radius: 18px;\n",
        "  padding: 20px 22px 18px; width: 100%; box-sizing:border-box;\n",
        "  margin: 0 auto; box-shadow: 0 6px 32px rgba(43,122,120,.1);\n",
        "}\n",
        ".se-dia .hdr { text-align:center; font-size:1.15em; font-weight:700; color:#2b6b6b; letter-spacing:.03em; margin-bottom:12px; }\n",
        ".se-dia .top { display:grid; grid-template-columns:3fr 2fr; grid-template-rows:auto auto; gap:10px; margin-bottom:12px; }\n",
        ".se-dia .top .net { grid-row:1/3; }\n",
