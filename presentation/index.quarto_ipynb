        "/* Exploration: green */\n",
        ".g.c-exp        { border-color:#98c8a4; background:rgba(200,230,210,.25); }\n",
        ".g.c-exp > .gl  { color:#3a7048; }\n",
        ".p.c-exp        { background:#a8d8b4; border-color:#70b480; color:#1e4a2a; }\n",
        "/* Analysis: slate blue */\n",
        ".g.c-ana        { border-color:#98a8c4; background:rgba(200,210,228,.25); }\n",
        ".g.c-ana > .gl  { color:#3a5070; }\n",
        ".p.c-ana        { background:#b0c0d8; border-color:#7898b8; color:#1e3450; }\n",
        "/* Environment: warm gray */\n",
        ".g.c-env        { border-color:#b0b8b8; background:rgba(215,220,220,.25); }\n",
        ".g.c-env > .gl  { color:#505858; }\n",
        ".p.c-env        { background:#c4cccc; border-color:#94a0a0; color:#2a3434; }\n",
        "</style>\n",
        "<div class=\"se-dia\">\n",
        "  <div class=\"hdr\">SimulationExperiment</div>\n",
        "  <div class=\"top\">\n",
        "    <div class=\"g c-net net\">\n",
        "      <div class=\"gl\">Network</div>\n",
        "      <div class=\"pp\">\n",
        "        <span class=\"p c-net opt\">Parcellation</span>\n",
